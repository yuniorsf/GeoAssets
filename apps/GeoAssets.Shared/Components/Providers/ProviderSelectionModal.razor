@inherits GeoAssets.Shared.Components.Localization.LocalizedComponentBase
@using GeoAssets.Core.Models
@using GeoAssets.Core.Services
@using Microsoft.Extensions.Logging
@inject IBootLoader BootLoader
@inject ProviderPluginRegistry Registry
@inject ILogger<ProviderSelectionModal> Logger

@if (!BootLoader.IsBootComplete)
{
    <div class="psm-overlay">
        <div class="psm-modal">

            <div class="psm-header">
                <span style="font-size:1.4rem">🗺️</span>
                <div>
                    <h2 class="psm-title">GeoAssets</h2>
                    <p class="psm-subtitle">Select a data source to get started</p>
                </div>
            </div>

            <div class="psm-body">

                <!-- Plugin list -->
                <ul class="psm-plugin-list">
                    @foreach (var plugin in Registry.All)
                    {
                        var p = plugin;
                        <li class="psm-plugin-item @(p == _selected ? "psm-plugin-item--active" : "")"
                            @onclick="() => SelectPlugin(p)">
                            <span class="psm-plugin-name">@p.DisplayName</span>
                            <span class="psm-plugin-desc">@p.Description</span>
                        </li>
                    }
                </ul>

                <!-- Config form for selected plugin -->
                <div class="psm-config">
                    @if (_selected is not null)
                    {
                        <h4 class="psm-config-title">@_selected.DisplayName</h4>
                        <ProviderConfigForm Plugin="_selected" Config="_config" />

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <p class="psm-error">@_error</p>
                        }
                    }
                    else
                    {
                        <p class="psm-hint">← Select a provider on the left</p>
                    }
                </div>
            </div>

            <div class="psm-footer">
                <button class="btn btn-secondary btn-sm" @onclick="Skip" disabled="@_connecting">
                    Skip — use empty workspace
                </button>
                <button class="btn btn-primary btn-sm" @onclick="ConnectAsync"
                        disabled="@(_connecting || _selected is null)">
                    @(_connecting ? "Connecting…" : "Connect")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private IProviderPlugin? _selected;
    private ProviderConfig   _config    = new();
    private string           _error     = string.Empty;
    private bool             _connecting;

    protected override void OnInitialized()
    {
        // Re-render when boot completes (auto-boot path)
        BootLoader.BootCompleted += (_, _) => InvokeAsync(StateHasChanged);

        if (Registry.All.Count > 0)
            SelectPlugin(Registry.All[0]);
    }

    private void SelectPlugin(IProviderPlugin plugin)
    {
        _selected = plugin;
        _config   = new ProviderConfig();
        _error    = string.Empty;
        // Defaults are pre-filled by ProviderConfigForm.OnParametersSet
    }

    private async Task ConnectAsync()
    {
        if (_selected is null) return;

        // Validate required fields
        foreach (var f in _selected.ConfigFields.Where(f => f.Required))
        {
            if (!_config.Has(f.Key))
            {
                _error = $"{f.Label} is required.";
                return;
            }
        }

        _connecting = true;
        _error      = string.Empty;
        StateHasChanged();

        try
        {
            await BootLoader.BootWithAsync(_selected, _config);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Provider boot failed — plugin: {Plugin}", _selected.Id);
        }
        finally
        {
            _connecting = false;
        }
    }

    private void Skip() => BootLoader.BootWithDefault();
}
