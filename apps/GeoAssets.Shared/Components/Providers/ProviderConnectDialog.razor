@inherits GeoAssets.Shared.Components.Localization.LocalizedComponentBase
@using GeoAssets.Core.Models
@using GeoAssets.Core.Services
@using Microsoft.Extensions.Logging
@inject IBootLoader BootLoader
@inject IProviderPool Pool
@inject ProviderPluginRegistry Registry
@inject IServiceProvider Services
@inject ILogger<ProviderConnectDialog> Logger

@* Shown at boot (IsBootMode=true) or at runtime (IsBootMode=false, Visible driven by the caller).
   In boot mode the dialog checks BootLoader.IsBootComplete directly so it can close itself
   when BootCompleted fires without waiting for the parent to re-render. *@

@if (IsBootMode ? !BootLoader.IsBootComplete : Visible)
{
    <div class="pcd-overlay" @onclick="HandleBackdropClick">
        <div class="pcd-modal" @onclick:stopPropagation="true">

            <div class="pcd-header">
                <span style="font-size:1.4rem">🗺️</span>
                <div>
                    <h2 class="pcd-title">@(IsBootMode ? "GeoAssets" : L["pool.addProvider"])</h2>
                    <p class="pcd-subtitle">
                        @(IsBootMode ? L["pool.bootSubtitle"] : L["pool.addSubtitle"])
                    </p>
                </div>
            </div>

            <div class="pcd-body">

                <!-- Plugin list -->
                <ul class="pcd-plugin-list">
                    @foreach (var plugin in Registry.All)
                    {
                        var p = plugin;
                        <li class="pcd-plugin-item @(p == _selected ? "pcd-plugin-item--active" : "")"
                            @onclick="() => SelectPlugin(p)">
                            <span class="pcd-plugin-name">@p.DisplayName</span>
                            <span class="pcd-plugin-desc">@p.Description</span>
                        </li>
                    }
                </ul>

                <!-- Dynamic config form for selected plugin -->
                <div class="pcd-config">
                    @if (_selected is not null)
                    {
                        <h4 class="pcd-config-title">@_selected.DisplayName</h4>
                        <ProviderConfigForm Plugin="_selected" Config="_config" />

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <p class="pcd-error">@_error</p>
                        }
                    }
                    else
                    {
                        <p class="pcd-hint">← @L["pool.selectProviderHint"]</p>
                    }
                </div>
            </div>

            <div class="pcd-footer">
                @if (IsBootMode)
                {
                    <button class="btn btn-secondary btn-sm" @onclick="SkipBoot" disabled="@_connecting">
                        @L["pool.skipBoot"]
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel" disabled="@_connecting">
                        @L["assets.cancel"]
                    </button>
                }
                <button class="btn btn-primary btn-sm" @onclick="ConnectAsync"
                        disabled="@(_connecting || _selected is null)">
                    @(_connecting ? L["pool.connecting"] : L["pool.connect"])
                </button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Controls dialog visibility. For boot mode, drive with <c>!BootLoader.IsBootComplete</c>.</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>
    /// True: dialog is the boot-time provider picker (shows Skip, routes through IBootLoader).
    /// False: dialog is the runtime "add provider" flow (shows Cancel, adds directly to pool).
    /// </summary>
    [Parameter] public bool IsBootMode { get; set; }

    /// <summary>Called when the dialog should close (Cancel pressed or connection succeeded in runtime mode).</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Called after a provider is successfully connected in runtime mode. Use this to render features on the map.</summary>
    [Parameter] public EventCallback<ProviderEntry> OnProviderConnected { get; set; }

    private IProviderPlugin? _selected;
    private ProviderConfig   _config    = new();
    private string           _error     = string.Empty;
    private bool             _connecting;

    protected override void OnInitialized()
    {
        // Re-render when auto-boot completes so the overlay disappears immediately
        if (IsBootMode)
            BootLoader.BootCompleted += (_, _) => InvokeAsync(StateHasChanged);

        if (Registry.All.Count > 0)
            SelectPlugin(Registry.All[0]);
    }

    protected override void OnParametersSet()
    {
        // Reset form every time the dialog is opened from outside (Visible flips false→true)
        if (Visible && _selected is null && Registry.All.Count > 0)
            SelectPlugin(Registry.All[0]);
    }

    private void SelectPlugin(IProviderPlugin plugin)
    {
        _selected = plugin;
        _config   = new ProviderConfig();
        _error    = string.Empty;
    }

    private async Task ConnectAsync()
    {
        if (_selected is null) return;

        foreach (var f in _selected.ConfigFields.Where(f => f.Required))
        {
            if (!_config.Has(f.Key))
            {
                _error = L.GetString("pool.fieldRequired", f.Label);
                return;
            }
        }

        _connecting = true;
        _error      = string.Empty;
        StateHasChanged();

        try
        {
            if (IsBootMode)
            {
                await BootLoader.BootWithAsync(_selected, _config);
                // BootCompleted event triggers StateHasChanged → overlay disappears
            }
            else
            {
                var provider = await _selected.CreateAsync(_config, Services);
                var name     = _config.Get("name", _selected.DisplayName);
                var entry    = Pool.AddExternal(name, provider);

                Logger.LogInformation("Provider connected — plugin: {Plugin}, name: {Name}, features: {Count}",
                    _selected.Id, name, provider.GetAll().Count);

                await OnProviderConnected.InvokeAsync(entry);
                await OnClose.InvokeAsync();

                // Reset for next open
                _selected = Registry.All.Count > 0 ? Registry.All[0] : null;
                _config   = new();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Provider connection failed — plugin: {Plugin}", _selected?.Id);
        }
        finally
        {
            _connecting = false;
        }
    }

    private void SkipBoot() => BootLoader.BootWithDefault();

    private void Cancel()
    {
        _error = string.Empty;
        OnClose.InvokeAsync();
    }

    // Close on backdrop click only in runtime mode (boot requires an explicit choice)
    private void HandleBackdropClick()
    {
        if (!IsBootMode && !_connecting)
            Cancel();
    }
}
