@* Warning overlay displayed when inactivity is about to expire the session. *@
@* Subscribes to SessionTimeoutService events and updates every second. *@

@implements IDisposable
@inject SessionTimeoutService SessionTimeout

@if (SessionTimeout.IsInWarning)
{
    <div class="sto-backdrop">
        <div class="sto-card">
            <div class="sto-icon">⏱️</div>
            <h2 class="sto-title">¿Sigues ahí?</h2>
            <p class="sto-body">
                Tu sesión expirará por inactividad en
            </p>
            <div class="sto-countdown">@SessionTimeout.SecondsLeft</div>
            <p class="sto-body">segundos.</p>
            <button class="sto-btn" @onclick="StayLoggedIn">
                Continuar sesión
            </button>
        </div>
    </div>
}

<style>
    .sto-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.75);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999;
        animation: fadeIn .2s ease;
    }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .sto-card {
        background: #1e1e2e;
        border: 1px solid #313244;
        border-radius: 16px;
        padding: 2.5rem 2.5rem;
        max-width: 360px;
        width: 90%;
        text-align: center;
        box-shadow: 0 32px 80px rgba(0,0,0,.6);
    }
    .sto-icon      { font-size: 3rem; margin-bottom: .5rem; }
    .sto-title     { color: #cdd6f4; font-size: 1.4rem; font-weight: 700; margin: 0 0 .75rem; }
    .sto-body      { color: #a6adc8; font-size: .9rem; margin: .25rem 0; }
    .sto-countdown {
        font-size: 3.5rem;
        font-weight: 800;
        color: #f38ba8;
        line-height: 1;
        margin: .75rem 0;
    }
    .sto-btn {
        margin-top: 1.25rem;
        width: 100%;
        padding: .75rem;
        background: #89b4fa;
        color: #11111b;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }
    .sto-btn:hover { background: #b4d0fb; }
</style>

@code {
    protected override void OnInitialized()
        => SessionTimeout.OnStateChanged += Refresh;

    private void StayLoggedIn()
        => SessionTimeout.RecordActivity();

    private void Refresh()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => SessionTimeout.OnStateChanged -= Refresh;
}
