@using GeoAssets.Core.Interfaces
@using GeoAssets.Core.Services
@using GeoAssets.Shared.Services
@using GeoAssets.Core.Diagnostics
@using System.Diagnostics
@using Microsoft.Extensions.Logging
@inject IStorageService Storage
@inject IAssetService AssetSvc
@inject IMapInterop MapInterop
@inject IAssetRepository Repository
@inject ILogger<ImportExportPanel> Logger
@inject IAnalyticsService Analytics

<div class="sidebar-section">
    <h6>Importar / Exportar</h6>
    <div class="import-export-panel">
        <button class="btn btn-outline btn-sm" @onclick="Export">
            ⬇ Exportar GeoJSON
        </button>

        <label class="btn btn-secondary btn-sm" style="cursor:pointer;text-align:center">
            ⬆ Importar GeoJSON
            <InputFile OnChange="ImportFile" accept=".geojson,.json" style="display:none" />
        </label>

        @if (_confirmingClear)
        {
            <div class="clear-confirm">
                <span>¿Eliminar todos los activos?</span>
                <div class="clear-confirm-actions">
                    <button class="btn btn-danger btn-xs" @onclick="ConfirmClear">Sí, limpiar</button>
                    <button class="btn btn-outline btn-xs" @onclick="() => _confirmingClear = false">Cancelar</button>
                </div>
            </div>
        }
        else
        {
            <button class="btn btn-danger btn-sm" @onclick="() => _confirmingClear = true">
                ✕ Limpiar mapa
            </button>
        }

        @if (!string.IsNullOrEmpty(_message))
        {
            <p style="font-size:0.78rem;color:var(--text-secondary);margin:4px 0">@_message</p>
        }
    </div>
</div>

@code {
    [Parameter] public string MapDivId { get; set; } = "geoassets-map";

    private string _message        = string.Empty;
    private bool   _confirmingClear = false;

    private async Task ConfirmClear()
    {
        _confirmingClear = false;
        try
        {
            await AssetSvc.ClearAllAsync();
            await MapInterop.ClearAllFeaturesAsync(MapDivId);
            _message = "Mapa limpiado.";
        }
        catch (Exception ex)
        {
            _message = $"Error al limpiar: {ex.Message}";
        }
    }

    private async Task Export()
    {
        try
        {
            var json = await AssetSvc.ExportAsync();
            await Storage.SaveExportFileAsync(json, "geoassets-export.geojson");
            _message = "Exportado correctamente.";
        }
        catch (Exception ex)
        {
            _message = $"Error al exportar: {ex.Message}";
        }
    }

    private async Task ImportFile(InputFileChangeEventArgs e)
    {
        var pipelineSw = Stopwatch.StartNew();

        // Parent span covers the entire import pipeline.
        using var pipeline = ImportDiagnostics.ActivitySource
            .StartActivity("import.pipeline", ActivityKind.Internal);
        pipeline?.SetTag("file.name",       e.File.Name)
                 .SetTag("file.size_bytes", e.File.Size);

        Logger.LogInformation("Import started — file: {FileName} ({FileSizeBytes} B)",
            e.File.Name, e.File.Size);
        try
        {
            using Stream? stream = e.File.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using StreamReader? reader = new System.IO.StreamReader(stream);
            string? json = await reader.ReadToEndAsync();

            ImportDiagnostics.PayloadBytes.Record(json.Length,
                new KeyValuePair<string, object?>(key: "file.name", e.File.Name));

            await AssetSvc.ImportAsync(json);

            IReadOnlyList<GeoFeature>? allFeatures = Repository.GetAll();

            await MapInterop.RenderAllFeaturesAsync(MapDivId, allFeatures);

            // ── Fit map ───────────────────────────────────────────────────────
            if (allFeatures.Count > 0)
            {
                var bbox = ComputeBbox(allFeatures);
                await MapInterop.FitBoundsAsync(MapDivId, bbox);
            }

            // ── Pipeline summary ──────────────────────────────────────────────
            pipelineSw.Stop();
            pipeline?.SetTag("feature.count",    allFeatures.Count)
                     .SetTag("total_duration_ms", pipelineSw.ElapsedMilliseconds);

            ImportDiagnostics.ImportDurationMs.Record(pipelineSw.Elapsed.TotalMilliseconds,
                new KeyValuePair<string, object?>("outcome", "success"));
            ImportDiagnostics.ImportCount.Add(1,
                new KeyValuePair<string, object?>("outcome", "success"));
            ImportDiagnostics.FeatureImportCount.Add(allFeatures.Count);

            Logger.LogInformation(
                "Import pipeline complete — {FileName}: {FeatureCount} features, {TotalMs} ms total",
                e.File.Name, allFeatures.Count, pipelineSw.ElapsedMilliseconds);

            Analytics.TrackEvent("import.completed", new {
                fileName     = e.File.Name,
                fileSizeBytes = e.File.Size,
                featureCount = allFeatures.Count,
                totalMs      = pipelineSw.ElapsedMilliseconds,
                outcome      = "success"
            });

            _message = $"{e.File.Name} importado ({allFeatures.Count} activos).";
        }
        catch (Exception ex)
        {
            pipelineSw.Stop();
            pipeline?.SetStatus(ActivityStatusCode.Error, ex.Message)
                     .AddException(ex);

            ImportDiagnostics.ImportCount.Add(1,
                new KeyValuePair<string, object?>("outcome", "failure"));

            Logger.LogError(ex,
                "Import failed — {FileName} after {ElapsedMs} ms",
                e.File.Name, pipelineSw.ElapsedMilliseconds);

            Analytics.TrackException(ex.Message, new {
                fileName = e.File.Name,
                elapsedMs = pipelineSw.ElapsedMilliseconds,
                outcome   = "failure"
            });

            _message = $"Error al importar: {ex.Message}";
        }
    }

    private static double[] ComputeBbox(IReadOnlyList<GeoAssets.Core.Models.GeoFeature> features)
    {
        var bboxes = features
            .Where(f => f.Geometry is not null)
            .Select(f => f.Geometry!.GetBoundingBox())
            .ToList();

        if (bboxes.Count == 0) return [0, 0, 0, 0];

        return [
            bboxes.Min(b => b[0]),
            bboxes.Min(b => b[1]),
            bboxes.Max(b => b[2]),
            bboxes.Max(b => b[3])
        ];
    }
}
